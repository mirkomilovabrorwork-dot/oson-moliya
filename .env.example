# PulTrack environment variables
# Copy to .env.local for local dev (gitignored). Set the same in Vercel for prod.

# --- Database (Neon Postgres) ---
DATABASE_URL=        # Neon POOLED connection string (host contains "-pooler"), ?sslmode=require
DIRECT_URL=          # Neon UNPOOLED connection string (used only by prisma migrate)

# --- AI brain (Anthropic Claude) ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001   # fast model for per-message extraction

# --- Voice -> text (STT; production uses ElevenLabs Scribe v2 for Uzbek accuracy) ---
ELEVENLABS_API_KEY=
GROQ_API_KEY=        # optional fallback for Groq Whisper
OPENAI_API_KEY=      # optional fallback for OpenAI gpt-4o-transcribe
STT_PROVIDER=elevenlabs    # elevenlabs | groq | openai

# --- Telegram bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=   # random string; sent as Telegram secret_token and checked on every webhook POST

# --- App / auth ---
APP_URL=http://localhost:3000   # public base URL (https://<project>.vercel.app in prod)
AUTH_SECRET=                    # random 32+ char string; HMAC for magic-link + session tokens

# --- Local dev only (NEVER set in production) ---
# ALLOW_INSECURE_DEV=1          # Bypasses Telegram magic-link auth so headless QA and local
#                               # browsers can reach authenticated pages without a real session.
#                               # HARD-BLOCKED IN PRODUCTION: the server refuses to start if
#                               # this is set while NODE_ENV=production (assertInsecureDevBlocked).
#                               # Never set this variable in your production/Vercel environment.
